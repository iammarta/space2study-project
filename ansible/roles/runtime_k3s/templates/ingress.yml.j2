apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: space2study-ingress
  namespace: space2study
  annotations:
    traefik.ingress.kubernetes.io/router.middlewares: space2study-strip-api-prefix@kubernetescrd
spec:
  ingressClassName: traefik
  rules:
    - host: "{{ app_domain }}"
      http:
        paths:
          - path: /api
            pathType: Prefix
            backend:
              service:
                name: backend
                port:
                  number: 5001
          - path: /
            pathType: Prefix
            backend:
              service:
                name: frontend
                port:
                  number: 80