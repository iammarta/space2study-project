# Ports
BACKEND_PORT=5001
FRONTEND_PORT=3000
GRAFANA_PORT=3001

# Database
MONGO_DB_URL=mongodb://mongodb:27017/database_name

# API Path for Frontend (use your local or server IP)
API_URL=http://localhost:5001

# Monitoring Security
GRAFANA_ADMIN_PASSWORD=your_secure_password_here

NEXUS_JVM_PARAMS="-Xms1200M -Xmx1200M -XX:MaxDirectMemorySize=512M"